<!DOCTYPE html>
<html lang="en-us">
<head>
<meta charset="utf-8"/>
<meta content="text/html; charset=utf-8" http-equiv="Content-Type"/>
<meta content="width=device-width, initial-scale=1.0, user-scalable=no" name="viewport"/>
<link href="https://cdn.jsdelivr.net/gh/ftbaldana/hello@main/TemplateData/favicon.ico" rel="shortcut icon"/>
<link href="https://cdn.jsdelivr.net/gh/ftbaldana/hello@main/TemplateData/style.css" rel="stylesheet"/>
<style>
  html,body{width:100%;height:100%;overflow:hidden;padding:0;margin:0;}
</style>
</head>
<body class="dark">

<div class="unity-desktop" id="unity-container">
  <canvas id="unity-canvas"></canvas>
</div>
<div id="loading-cover" style="display:none;">
  <div id="unity-loading-bar">
    <div id="unity-logo"><img src="https://cdn.jsdelivr.net/gh/ftbaldana/hello@main/logo.png"/></div>
    <div id="unity-progress-bar-empty" style="display:none;">
      <div id="unity-progress-bar-full"></div>
    </div>
    <div class="spinner"></div>
  </div>
</div>

<script>
/* ============================================================
   CONFIG — CDN adresini doldurun
   ============================================================ */
var CDN        = "https://cdn.jsdelivr.net/gh/ftbaldana/hello@c7a28b7/Build";   /* <-- degistir */
var DATA_PARTS = 4;   /* 30.5MB / 8MB = 4 part */

var PREFIX   = "TPG_TsunamiBrainrotsOnline_V06-5";
var buildUrl = CDN;

var config = {
  dataUrl:            null,   /* part'lardan blob olarak set edilir */
  frameworkUrl:       buildUrl + "/" + PREFIX + ".framework.js.unityweb",
  codeUrl:            buildUrl + "/" + PREFIX + ".wasm.unityweb",
  streamingAssetsUrl: "StreamingAssets",
  companyName:        "Cursora Labs OU",
  productName:        "Tsunami Brainrots Online",
  productVersion:     "0.1a",
  devicePixelRatio:   1.5,
  webglContextAttributes: {
    preserveDrawingBuffer: true,
    powerPreference: "high-performance"
  }
};

var container        = document.querySelector("#unity-container");
var canvas           = document.querySelector("#unity-canvas");
var loadingCover     = document.querySelector("#loading-cover");
var progressBarEmpty = document.querySelector("#unity-progress-bar-empty");
var progressBarFull  = document.querySelector("#unity-progress-bar-full");
var spinner          = document.querySelector('.spinner');

loadingCover.style.display = "";
document.body.style.backgroundImage    = "url('https://cdn.jsdelivr.net/gh/ftbaldana/hello@main/background.png')";
document.body.style.backgroundPosition = "center";
document.body.style.backgroundRepeat   = "no-repeat";
document.body.style.backgroundSize     = "cover";

/* ── PART İNDİRME ─────────────────────────────────────────── */
async function fetchParts(baseUrl, partCount) {
  var parts = [];
  for (var i = 0; i < partCount; i++) {
    var r = await fetch(baseUrl + '.part' + i);
    if (!r.ok) throw new Error('part' + i + ': HTTP ' + r.status);
    parts.push(new Uint8Array(await r.arrayBuffer()));
  }
  var total  = parts.reduce(function(s,p){ return s + p.length; }, 0);
  var merged = new Uint8Array(total);
  var off = 0;
  for (var j = 0; j < parts.length; j++) { merged.set(parts[j], off); off += parts[j].length; }
  return merged;
}

function brotliBlobUrl(uint8, filename) {
  var blob = new Blob([uint8], { type: 'application/octet-stream' });
  return URL.createObjectURL(blob) + '#' + encodeURIComponent(filename);
}

/* ── LOADER ───────────────────────────────────────────────── */
var script = document.createElement("script");
script.src = buildUrl + "/" + PREFIX + ".loader.js";
script.onload = async function() {
  try {
    var dataBytes = await fetchParts(
      buildUrl + "/" + PREFIX + ".data.unityweb", DATA_PARTS);
    config.dataUrl = brotliBlobUrl(dataBytes, PREFIX + ".data.unityweb");
  } catch(e) {
    console.error("Data indirme hatasi:", e);
    alert("Data load error: " + e.message);
    return;
  }

  createUnityInstance(canvas, config, function(progress) {
    spinner.style.display          = "none";
    progressBarEmpty.style.display = "";
    progressBarFull.style.width    = (100 * progress) + '%';
  }).then(function(unityInstance) {
    myGameInstance = unityInstance;
    loadingCover.style.display = "none";
  }).catch(function(message) {
    alert(message);
  });
};

var myGameInstance = null;
document.body.appendChild(script);
</script>

<!-- h5-sdk stub + ad fonksiyonlari -->
<script>
window.adsbygoogle = window.adsbygoogle || [];
var adBreak, adConfig;
adBreak = adConfig = function(o){ adsbygoogle.push(o); };
adConfig({ sound:'on', preloadAdBreaks:'on' });

var interstitialCounter = 0;

function initSdk() {
  console.log('"Init SDK" Called');
}

function showInterstitial() {
  if (++interstitialCounter === 1) {
    console.log("Interstitial skipped this time");
    return;
  }
  adBreak({
    type:'next', name:'restart-game',
    beforeAd:    sendMsgPauseGameBeforeAds,
    afterAd:     sendMsgResumeGameAfterAds,
    adBreakDone: function(p){ console.log("Interstitial status: "+p.breakStatus); }
  });
}

function showRewarded() {
  if (!adsbygoogle.loaded) {
    console.log("Rewarded could not load");
    sendMsgRewardedAdsFailed();
    return;
  }
  adBreak({
    type:'reward', name:'extra-life',
    beforeAd:     sendMsgPauseGameBeforeAds,
    afterAd:      sendMsgResumeGameAfterAds,
    beforeReward: function(fn){ fn(); },
    adDismissed:  sendMsgRewardedAdsDismissed,
    adViewed:     sendMsgRewardSuccessful,
    adBreakDone:  function(p){
      console.log("Reward status: "+p.breakStatus);
      if (p.breakStatus !== 'viewed' && p.breakStatus !== 'dismissed')
        sendMsgRewardedAdsFailed();
    }
  });
}

function sendMsgRewardedAdsFailed()    { console.info("Reward failed");     if(myGameInstance) myGameInstance.SendMessage('RHMAdsManager','RewardedAdsFailed');     refocusCanvas(); }
function sendMsgRewardedAdsDismissed() { console.info("Reward dismissed");  if(myGameInstance) myGameInstance.SendMessage('RHMAdsManager','RewardedAdsDismissed'); }
function sendMsgRewardSuccessful()     { console.info("Reward successful"); if(myGameInstance) myGameInstance.SendMessage('RHMAdsManager','RewardedAdsSuccessfull'); }
function sendMsgPauseGameBeforeAds()   { console.info("Pause before ads"); if(myGameInstance) myGameInstance.SendMessage('RHMAdsManager','pauseGame'); }
function sendMsgResumeGameAfterAds()   { console.info("Resume after ads"); if(myGameInstance) myGameInstance.SendMessage('RHMAdsManager','resumeGame'); refocusCanvas(); }

function refocusCanvas() {
  if (!canvas.hasAttribute('tabIndex')) canvas.setAttribute('tabIndex','0');
  canvas.focus();
}
</script>
<style>
  /* Container: Top center, fixed, with overflow hidden */
  #ad-container {
    position: fixed;
    top: 0; /* Üst kısma sabitlendi */
    left: 50%;
    transform: translateX(-50%);
    width: min(728px, calc(100% - 20px)); 
    height: 90px;
    background: rgba(0, 0, 0, 0.90);
    display: none;
    z-index: 99999;
    border-radius: 0; 
    overflow: hidden;
    box-shadow: 0 2px 12px rgba(0, 0, 0, 0.45); /* Gölge yönü aşağı verildi */
    box-sizing: border-box;
    transition: transform 0.5s ease-in-out; 
  }

  /* Slide-out animation */
  #ad-container.hidden {
    transform: translate(-50%, -100%); /* Yukarı doğru gizlenir */
  }

  #ad-iframe {
    position: absolute;
    top: 0;
    left: 50%;
    transform: translateX(-50%);
    width: 745px; 
    height: 90px; 
    border: 0;
    display: block;
    overflow: hidden;
    pointer-events: auto;
    box-sizing: content-box;
    -ms-overflow-style: none;
    scrollbar-width: none;
  }
  
  #ad-iframe::-webkit-scrollbar {
    display: none;
    width: 0;
    height: 0;
  }

  /* Close button with arrow */
  #close-ad {
    position: absolute;
    bottom: 6px; /* Üst reklamda buton genellikle alt köşede daha erişilebilirdir, istersen top:6px yapabilirsin */
    right: 8px;
    background: #ff4d4d;
    color: #fff;
    border: none;
    padding: 5px 9px;
    font-size: 13px;
    border-radius: 4px;
    cursor: not-allowed;
    opacity: 0.72;
    z-index: 100000;
    display: flex;
    align-items: center;
  }
  #close-ad.enabled {
    cursor: pointer;
    opacity: 1;
  }
  #close-ad::before {
    content: '↑'; /* Üst reklam için yukarı ok */
    margin-right: 4px;
  }

  /* Right mask for scrollbar */
  #ad-right-mask {
    position: absolute;
    top: 0;
    right: 0;
    width: 12px;
    height: 100%;
    pointer-events: none;
    background: linear-gradient(to right, rgba(0, 0, 0, 0), rgba(0, 0, 0, 0.9));
    z-index: 99999;
  }

  /* Mobile adjustments */
  @media (max-width: 440px) {
    #ad-container {
      width: calc(100% - 12px);
      left: 50%;
      transform: translateX(-50%);
      border-radius: 0;
    }
    #ad-iframe {
      width: 728px;
    }
  }
</style>

<div id="ad-container" aria-hidden="true" role="dialog" aria-label="Advertisement">
  <iframe
    id="ad-iframe"
    src="https://script.google.com/macros/s/AKfycbxLG5DHBe-sIbduDvwQZYJ3oaX_ha7rsvroprCFkQsnpZK_PEdipNia5ghxI_sdXYpv/exec"
    width="768px"
    height="95px"
    scrolling="no"
    frameborder="0"
    sandbox="allow-scripts allow-popups allow-same-origin"
  ></iframe>
  <button id="close-ad" disabled>Close (12)</button>
  <div id="ad-right-mask"></div>
</div>

<script>
  (function () {
    const showDelay = 2000; 
    const countdownStart = 12; 
    const reappearDelay = 150000; 
    const adContainer = document.getElementById('ad-container');
    const closeBtn = document.getElementById('close-ad');

    function showAd() {
      adContainer.style.display = 'block';
      adContainer.classList.remove('hidden');
      adContainer.setAttribute('aria-hidden', 'false');

      let timeLeft = countdownStart;
      closeBtn.textContent = `Close (${timeLeft})`;
      closeBtn.disabled = true;
      closeBtn.classList.remove('enabled');

      const t = setInterval(() => {
        timeLeft--;
        if (timeLeft > 0) {
          closeBtn.textContent = `Close (${timeLeft})`;
        } else {
          clearInterval(t);
          closeBtn.disabled = false;
          closeBtn.classList.add('enabled');
          closeBtn.textContent = 'Close ↑';
        }
      }, 1000);
    }

    setTimeout(showAd, showDelay);

    closeBtn.addEventListener('click', () => {
      if (closeBtn.disabled) return;
      adContainer.classList.add('hidden');
      adContainer.setAttribute('aria-hidden', 'true');
      setTimeout(showAd, reappearDelay);
    });
  })();
</script>
</body>
</html>


